  "publicApiSurface": [
    "sync_playwright() - Synchronous Playwright context manager",
    "async_playwright() - Asynchronous Playwright context manager",
    "page.goto() - Navigate to URL",
    "page.get_by_role() - Locate elements by ARIA role",
    "page.get_by_placeholder() - Locate inputs by placeholder",
    "page.locator() - Create element locator",
    "expect(page).to_have_url() - Assert page URL",
    "expect(page).to_have_title() - Assert page title",
    "expect(locator).to_be_visible() - Assert element visibility",
    "context.tracing.start() - Start trace recording",
    "context.new_page() - Create new page in context",
    "browser.new_context() - Create new browser context",
    "playwright.chromium.launch() - Launch Chromium browser"
